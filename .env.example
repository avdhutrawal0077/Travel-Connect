# Copy this file to backend/.env and fill in your values.
# Never commit .env files.

# Aiven MySQL connection string (used by config.py → DATABASE_URL)
DATABASE_URL=mysql+pymysql://avnadmin:YOUR_PASSWORD@your-service.aivencloud.com:25176/defaultdb

# JWT secret for token signing
JWT_SECRET_KEY=your-jwt-secret-here

# Flask settings
FLASK_APP=app.py
FLASK_ENV=development

# Email Configuration for OTP
MAIL_USERNAME=your_project_email@gmail.com
MAIL_PASSWORD=your_app_password
